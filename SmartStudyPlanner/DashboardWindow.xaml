<Window x:Class="SmartStudyPlanner.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Study Planner - Dashboard" Height="500" Width="700"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock x:Name="txtTieuDe" Text="TỔNG QUAN HỌC KỲ" FontWeight="Bold" FontSize="22" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,10" />
        <TextBlock x:Name="txtThongKe" Text="Bạn đang có X môn học và Y bài tập cần hoàn thành." FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <Button x:Name="btnQuanLyMonHoc" Content="📚 Quản lý Môn Học &amp; Bài Tập" Height="40" Width="250" FontWeight="Bold" 
                    Background="#3498DB" Foreground="White" Cursor="Hand" Click="BtnQuanLyMonHoc_Click" Margin="0,0,10,0"/>

            <Button x:Name="btnLuuDuLieu" Content="💾 Lưu Tiến Trình" Height="40" Width="150" FontWeight="Bold" 
                    Background="#F39C12" Foreground="White" Cursor="Hand" Click="BtnLuuDuLieu_Click" />
        </StackPanel>

        <TextBlock Text="🔥 TOP 5 DEADLINE KHẨN CẤP NHẤT" FontWeight="Bold" FontSize="16" Foreground="#E74C3C" Margin="0,0,0,10" />

        <DataGrid x:Name="dgTop5Task" Height="200" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="Khẩn cấp">
                            <Setter Property="Background" Value="#FFCDD2" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="Chú ý">
                            <Setter Property="Background" Value="#FFF9C4" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="An toàn">
                            <Setter Property="Background" Value="#C8E6C9" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Môn Học" Binding="{Binding TenMonHoc}" Width="150" FontWeight="Bold"/>
                <DataGridTextColumn Header="Tên Bài Tập" Binding="{Binding TenTask}" Width="*" />
                <DataGridTextColumn Header="Hạn Chót" Binding="{Binding HanChot, StringFormat=dd/MM/yyyy}" Width="100" />
                <DataGridTextColumn Header="Điểm Ưu Tiên" Binding="{Binding DiemUuTien}" Width="100" />
                <DataGridTextColumn Header="Mức Độ" Binding="{Binding MucDoCanhBao}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window>