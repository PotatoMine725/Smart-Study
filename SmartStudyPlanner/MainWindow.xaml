<Window x:Class="SmartStudyPlanner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smart Study Planner" Height="250" Width="400">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,30,0,0">

        <TextBlock x:Name="txtTrangThai" Text="Vui lòng nhập tên Học kỳ:" FontSize="16" HorizontalAlignment="Center" Margin="0,0,0,10" />

        <TextBox x:Name="txtTenHocKy" Width="200" Height="30" FontSize="14" Padding="5" Margin="0,0,0,15" />

        <TextBlock Text="Ngày bắt đầu:" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5" />
        
        <DatePicker x:Name="dpNgayBatDau" Width="200" Height="30" Margin="0,0,0,20" />

        <Button x:Name="btnTaoHocKy" Content="Tạo Học Kỳ Mới" Padding="15,10" FontSize="14" Click="BtnTaoHocKy_Click" />

    </StackPanel>
</Window>