<Window x:Class="SmartStudyPlanner.QuanLyTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Bài Tập / Deadline" Height="550" Width="750"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">
        <TextBlock x:Name="txtTieuDe" Text="QUẢN LÝ DEADLINE - MÔN TÊN MÔN" FontWeight="Bold" FontSize="18" Foreground="#8E44AD" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Tên bài tập:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="txtTenTask" Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,20,10" Padding="5" VerticalContentAlignment="Center"/>

            <TextBlock Text="Hạn chót:" Grid.Row="0" Grid.Column="2" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="Gray"/>
            <DatePicker x:Name="dpHanChot" Grid.Row="0" Grid.Column="3" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"/>

            <TextBlock Text="Loại sự kiện:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="Gray"/>
            <ComboBox x:Name="cmbLoaiTask" Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,20,10" VerticalContentAlignment="Center">
                <ComboBoxItem Content="Bài Tập Về Nhà" IsSelected="True"/>
                <ComboBoxItem Content="Kiểm Tra Thường Xuyên"/>
                <ComboBoxItem Content="Thi Giữa Kỳ"/>
                <ComboBoxItem Content="Đồ Án Cuối Kỳ"/>
                <ComboBoxItem Content="Thi Cuối Kỳ"/>
            </ComboBox>

            <TextBlock Text="Độ khó (1-5):" Grid.Row="1" Grid.Column="2" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="Gray"/>
            <TextBox x:Name="txtDoKho" Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,10" Padding="5" VerticalContentAlignment="Center"/>
        </Grid>

        <Button x:Name="btnThemTask" Content="Thêm Deadline" Height="35" Width="200" FontWeight="Bold" 
                Background="#9B59B6" Foreground="White" Cursor="Hand" Click="BtnThemTask_Click" Margin="0,0,0,20" />

        <DataGrid x:Name="dgDanhSachTask" Height="220" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="#F9F9F9">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Bài Tập" Binding="{Binding TenTask}" Width="*" />
                <DataGridTextColumn Header="Hạn Chót" Binding="{Binding HanChot, StringFormat=dd/MM/yyyy}" Width="100" />
                <DataGridTextColumn Header="Loại" Binding="{Binding LoaiTask}" Width="120" />
                <DataGridTextColumn Header="Độ Khó" Binding="{Binding DoKho}" Width="60" />
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="100" />
                <DataGridTextColumn Header="Điểm Ưu Tiên" Binding="{Binding DiemUuTien}" Width="90" FontWeight="Bold" Foreground="#E74C3C"/>

                <DataGridTemplateColumn Header="Thao tác" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Sửa" Background="#F1C40F" Foreground="White" Padding="10,2" Margin="0,0,5,0" Cursor="Hand" Click="BtnSuaTask_Click" />
                                <Button Content="Xóa" Background="#E74C3C" Foreground="White" Padding="10,2" Cursor="Hand" Click="BtnXoaTask_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Window>