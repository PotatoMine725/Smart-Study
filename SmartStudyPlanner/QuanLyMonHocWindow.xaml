<Window x:Class="SmartStudyPlanner.QuanLyMonHocWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quản Lý Môn Học" Height="500" Width="750"
        WindowStartupLocation="CenterScreen">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="20">
        <TextBlock x:Name="txtTieuDe" Text="DANH SÁCH MÔN HỌC" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5" Width="450">
            <TextBlock Text="Tên môn học" Width="250" Margin="0,0,10,0" Foreground="Gray" />
            <TextBlock Text="Tín chỉ" Width="60" Margin="0,0,10,0" Foreground="Gray" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20" Width="450">
            <TextBox x:Name="txtTenMon" Width="250" Height="30" Padding="5" Margin="0,0,10,0" VerticalContentAlignment="Center" />
            <TextBox x:Name="txtSoTinChi" Width="60" Height="30" Padding="5" Margin="0,0,10,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" />
            <Button x:Name="btnThemMon" Content="Thêm Môn" Width="120" Height="30" FontWeight="Bold" 
                    Background="#2ECC71" Foreground="White" Cursor="Hand" Click="BtnThemMon_Click" />
        </StackPanel>

        <DataGrid x:Name="dgDanhSachMon" Width="450" Height="250" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Môn Học" Binding="{Binding TenMonHoc}" Width="*" />
                <DataGridTextColumn Header="Số Tín Chỉ" Binding="{Binding SoTinChi}" Width="80" />
                <DataGridTemplateColumn Header="Thao tác" Width="110">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Tasks" Background="#9B59B6" Foreground="White" 
                                        Padding="10,2" Margin="0,0,5,0" Cursor="Hand" Click="BtnXemTask_Click" />
                                
                                <Button Content="Sửa" Background="#F1C40F" Foreground="White" 
                                        Padding="10,2" Margin="0,0,5,0" Cursor="Hand" Click="BtnSuaMon_Click" />

                                <Button Content="Xóa" Background="#E74C3C" Foreground="White" 
                                        Padding="10,2" Cursor="Hand" Click="BtnXoaMon_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <Button x:Name="btnLuu" Content="💾 Lưu Dữ Liệu Học Kỳ" Width="200" Height="35" FontWeight="Bold" 
                Background="#F39C12" Foreground="White" Cursor="Hand" Margin="0,15,0,0" Click="BtnLuu_Click" />
    </StackPanel>
</Window>