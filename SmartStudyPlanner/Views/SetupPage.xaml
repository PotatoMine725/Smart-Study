<Page x:Class="SmartStudyPlanner.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SetupPage"
      Background="{DynamicResource AppBackground}">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="400">
            <TextBlock Text="🎓 SMART STUDY PLANNER" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <StackPanel Margin="0,0,0,30">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding CoHocKyCu}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <TextBlock Text="Tiếp tục Học kỳ đã lưu:" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Grid.Column="0" ItemsSource="{Binding DanhSachHocKyCu}" SelectedItem="{Binding HocKyDuocChon}" DisplayMemberPath="Ten" Height="35" Margin="0,0,10,0" VerticalContentAlignment="Center" FontSize="14"/>

                    <Button Grid.Column="1" Content="Tiếp tục ➔" Command="{Binding TiepTucHocKyCuCommand}" Width="100" Height="35" Background="#27AE60" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </Grid>

                <Separator Margin="0,20,0,0" Background="#BDC3C7"/>
            </StackPanel>

            <TextBlock Text="Hoặc Tạo Học kỳ mới:" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10"/>

            <TextBlock Text="Tên Học Kỳ (vd: Học kỳ 1 - 2026):" Margin="0,0,0,5"/>
            <TextBox Text="{Binding TenHocKy, UpdateSourceTrigger=PropertyChanged}" Height="35" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryText}" Padding="5" VerticalContentAlignment="Center" FontSize="14"/>

            <TextBlock Text="Ngày Bắt Đầu:" Margin="0,0,0,5"/>
            <DatePicker SelectedDate="{Binding NgayBatDau}" Height="35" Margin="0,0,0,15" Foreground="{DynamicResource PrimaryText}" VerticalContentAlignment="Center" FontSize="14"/>

            <TextBlock Text="Ngày Kết Thúc (mặc định +150 ngày):" Margin="0,0,0,5"/>
            <DatePicker SelectedDate="{Binding NgayKetThuc}" Height="35" Margin="0,0,0,10" Foreground="{DynamicResource PrimaryText}" VerticalContentAlignment="Center" FontSize="14"/>
            <TextBlock Text="{Binding IsNgayKetThucAuto, StringFormat=Tự động: {0}}" Foreground="{DynamicResource SecondaryText}" FontSize="12" Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                <Button Content="Tự động tính lại" Command="{Binding TuDongTinhLaiCommand}" Width="140" Height="32" Margin="0,0,8,0" Background="#95A5A6" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
            </StackPanel>

            <Button Content="TẠO MỚI VÀ BẮT ĐẦU" Command="{Binding TaoHocKyCommand}" Height="40" Background="#2980B9" Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Page>