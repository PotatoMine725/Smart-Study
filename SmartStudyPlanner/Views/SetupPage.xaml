<Page x:Class="SmartStudyPlanner.SetupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="SetupPage">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,100,0,0">
        <TextBlock Text="THIẾT LẬP HỌC KỲ" FontWeight="Bold" FontSize="22" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <TextBlock Text="Tên Học kỳ (VD: Học kỳ 1 - 2026):" FontSize="14" Margin="0,0,0,5" Foreground="#555555" />
        <TextBox x:Name="txtTenHocKy" Width="300" Height="30" FontSize="14" Padding="5" Margin="0,0,0,15" VerticalContentAlignment="Center" />

        <TextBlock Text="Ngày bắt đầu:" FontSize="14" Margin="0,0,0,5" Foreground="#555555" />
        <DatePicker x:Name="dpNgayBatDau" Width="300" Height="30" Margin="0,0,0,20" VerticalContentAlignment="Center" />

        <Button x:Name="btnTaoHocKy" Content="Bắt đầu lên kế hoạch ➔" Height="40" Width="300" FontSize="14" FontWeight="Bold" 
                Background="#3498DB" Foreground="White" Cursor="Hand" Click="BtnTaoHocKy_Click" />
    </StackPanel>
</Page>