<Page x:Class="SmartStudyPlanner.QuanLyTaskPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản Lý Bài Tập / Deadline"
      Background="{DynamicResource AppBackground}">

    <StackPanel Margin="20">
        <Button Content="⬅ Quay lại Môn Học" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent" Foreground="#3498DB" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,10"
                Command="{Binding QuayLaiCommand}"/>

        <TextBlock Text="{Binding TieuDe}" FontWeight="Bold" FontSize="18" Foreground="#8E44AD" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="⚡ Nhập liệu Siêu tốc (Smart Add):" FontWeight="Bold" Foreground="#8E44AD" Margin="0,0,0,5"/>
                <TextBlock Text="Dán tin nhắn của lớp trưởng vào đây. VD: 'T6 tuần sau nộp btl căng lắm'" FontSize="12" Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" Text="{Binding VanBanNhapNhanh, UpdateSourceTrigger=PropertyChanged}" Height="35" Padding="5" VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                    <Button Grid.Column="1" Content="Tự điền 🪄" Command="{Binding PhanTichNhapNhanhCommand}" Width="80" Background="#8E44AD" Foreground="White" FontWeight="Bold" Cursor="Hand"/>
                </Grid>
            </StackPanel>
        </Border>

        <Separator Margin="0,0,0,20"/>

        <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Tên bài tập:" Grid.Row="0" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
            <TextBox Grid.Row="0" Grid.Column="1" Height="30" Margin="0,0,20,10" Padding="5" VerticalContentAlignment="Center"
                     Text="{Binding TenTask, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Hạn chót:" Grid.Row="0" Grid.Column="2" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
            <DatePicker Grid.Row="0" Grid.Column="3" Height="30" Margin="0,0,0,10" VerticalContentAlignment="Center"
                        SelectedDate="{Binding HanChot}"/>

            <TextBlock Text="Loại sự kiện:" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
            <ComboBox Grid.Row="1" Grid.Column="1" Height="30" Margin="0,0,20,10" VerticalContentAlignment="Center"
                      SelectedIndex="{Binding LoaiTaskIndex}">
                <ComboBoxItem Content="Bài Tập Về Nhà"/>
                <ComboBoxItem Content="Kiểm Tra Thường Xuyên"/>
                <ComboBoxItem Content="Thi Giữa Kỳ"/>
                <ComboBoxItem Content="Đồ Án Cuối Kỳ"/>
                <ComboBoxItem Content="Thi Cuối Kỳ"/>
            </ComboBox>

            <TextBlock Text="Độ khó (1-5):" Grid.Row="1" Grid.Column="2" Margin="0,0,10,10" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryText}"/>
            <TextBox Grid.Row="1" Grid.Column="3" Height="30" Margin="0,0,0,10" Padding="5" VerticalContentAlignment="Center"
                     Text="{Binding DoKho, UpdateSourceTrigger=PropertyChanged}"/>
        </Grid>

        <Button Height="35" Width="200" FontWeight="Bold" Foreground="White" Cursor="Hand" Margin="0,0,0,20" 
                Content="{Binding TextNutThem}"
                Background="{Binding MauNutThem}"
                Command="{Binding ThemTaskCommand}" />

        <DataGrid x:Name="dgDanhSachTask" Height="220" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                  ItemsSource="{Binding MonHocHienTai.DanhSachTask}"
                  Background="{DynamicResource CardBackground}" Foreground="{DynamicResource PrimaryText}">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Padding" Value="8,5" />
                    <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                </Style>
            </DataGrid.Resources>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />

                    <Style.Triggers>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="Khẩn cấp">
                            <Setter Property="Background" Value="#FFCDD2" />
                            <Setter Property="Foreground" Value="Black" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="Chú ý">
                            <Setter Property="Background" Value="#FFF9C4" />
                            <Setter Property="Foreground" Value="Black" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="An toàn">
                            <Setter Property="Background" Value="#C8E6C9" />
                            <Setter Property="Foreground" Value="Black" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding MucDoCanhBao}" Value="Đã xong">
                            <Setter Property="Background" Value="#E0E0E0" />
                            <Setter Property="Foreground" Value="#7F8C8D" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Bài Tập" Binding="{Binding TenTask}" Width="*" />
                <DataGridTextColumn Header="Hạn Chót" Binding="{Binding HanChot, StringFormat=dd/MM/yyyy}" Width="100" />
                <DataGridTextColumn Header="Loại" Binding="{Binding LoaiTask}" Width="120" />
                <DataGridTextColumn Header="Độ Khó" Binding="{Binding DoKho}" Width="60" />
                <DataGridTextColumn Header="Trạng Thái" Binding="{Binding TrangThai}" Width="100" />
                <DataGridTextColumn Header="Điểm Ưu Tiên" Binding="{Binding DiemUuTien}" Width="90" FontWeight="Bold" Foreground="#E74C3C"/>

                <DataGridTemplateColumn Header="Thao tác" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Xong" Background="#2ECC71" Foreground="White" Padding="10,2" Margin="0,0,5,0" Cursor="Hand" 
                                        Command="{Binding DataContext.HoanThanhTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" />

                                <Button Content="Sửa" Background="#F1C40F" Foreground="White" Padding="10,2" Margin="0,0,5,0" Cursor="Hand" 
                                        Command="{Binding DataContext.SuaTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" />

                                <Button Content="Xóa" Background="#E74C3C" Foreground="White" Padding="10,2" Cursor="Hand" 
                                        Command="{Binding DataContext.XoaTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" 
                                        CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>