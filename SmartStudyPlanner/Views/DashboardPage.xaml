<Page x:Class="SmartStudyPlanner.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
      Title="Dashboard" Loaded="Page_Loaded"
      Background="{DynamicResource AppBackground}">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,10,0">

        <StackPanel Margin="20">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <TextBlock Text="{Binding TieuDe}" FontWeight="Bold" FontSize="22" Foreground="{DynamicResource PrimaryText}" Margin="0,0,20,0" VerticalAlignment="Center" />

                <Border Background="{DynamicResource WarningBackground}" BorderBrush="{DynamicResource WarningColor}" BorderThickness="1" CornerRadius="12" Padding="15,4">
                    <TextBlock Text="{Binding ChuoiStreak}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource WarningColor}" VerticalAlignment="Center" ToolTip="Chuỗi ngày duy trì học tập liên tục!" />
                </Border>
            </StackPanel>

            <TextBlock Text="{Binding ThongKe}" FontSize="14" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center" Margin="0,0,0,20" />

<Grid Height="220" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Tỉ lệ hoàn thành" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                    <Border Background="{DynamicResource ChartBackground}" CornerRadius="8" Padding="10">
                        <lvc:PieChart Height="170" Series="{Binding BieuDoTrangThai}" LegendPosition="Right" />
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                    <TextBlock Text="Khối lượng bài tập" FontWeight="Bold" Foreground="{DynamicResource SecondaryText}" HorizontalAlignment="Center"/>
                    <Border Background="{DynamicResource ChartBackground}" CornerRadius="8" Padding="10">
                        <lvc:CartesianChart Height="170" Series="{Binding BieuDoMonHoc}" XAxes="{Binding TrucXMonHoc}" />
                    </Border>
                </StackPanel>
            </Grid>

            <TextBlock Text="🔥 TOP 5 DEADLINE KHẨN CẤP NHẤT" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource DangerColor}" Margin="0,0,0,10" />

            <DataGrid Height="260" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" ItemsSource="{Binding Top5Task}"
                      Background="{DynamicResource CardBackground}" Foreground="{DynamicResource PrimaryText}">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        <Setter Property="FontWeight" Value="Bold" />
                        <Setter Property="Padding" Value="8,5" />
                        <Setter Property="BorderBrush" Value="{DynamicResource BorderColor}" />
                        <Setter Property="BorderThickness" Value="0,0,0,1" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryText}" />
                        <Setter Property="Background" Value="{DynamicResource CardBackground}" />
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Môn Học" Binding="{Binding TenMonHoc}" Width="130" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Tên Bài Tập" Binding="{Binding TenTask}" Width="*" />
                    <DataGridTextColumn Header="Hạn Chót" Binding="{Binding HanChot, StringFormat=dd/MM/yyyy}" Width="90" />
                    <DataGridTextColumn Header="Đã học" Binding="{Binding TaskGoc.ThoiGianDaHoc, StringFormat={}{0} phút}" Width="75" Foreground="{DynamicResource SecondaryText}" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Điểm ƯT" Binding="{Binding DiemUuTien}" Width="75" />
                    <DataGridTextColumn Header="Mức Độ" Binding="{Binding MucDoCanhBao}" Width="85" />
                    <DataGridTextColumn Header="Rủi Ro" Binding="{Binding MucDoRuiRo}" Width="130" FontWeight="Bold"/>
                    <DataGridTextColumn Header="Cần học thêm" Binding="{Binding ThoiGianGoiY}" Width="120" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/>

                    <DataGridTemplateColumn Header="Thao tác" Width="185">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="HỌC NGAY"
                                        Command="{Binding DataContext.MoFocusModeCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource DangerColor}" Foreground="White"
                                        FontWeight="Bold" Padding="10,4" Margin="0,0,5,0"/>

                                    <Button Content="Đi tới"
                                        Command="{Binding DataContext.DiToiTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Background="{DynamicResource AccentColor}" Foreground="White"
                                        Padding="10,4"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Text="{Binding TieuDeLichHomNay}" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource SuccessColor}" Margin="0,20,0,10" />

            <ItemsControl ItemsSource="{Binding LichHocHomNay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="5" Padding="10" Margin="0,0,0,5" BorderBrush="{DynamicResource BorderColor}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding TenTask}" FontWeight="Bold" Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="{Binding TenMon}" FontSize="12" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding ThoiGianHienThi}" FontWeight="Bold" Foreground="#E67E22" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="📈 TIẾN ĐỘ THỜI GIAN HỌC" FontWeight="Bold" FontSize="16" Foreground="{DynamicResource AccentColor}" Margin="0,20,0,10" />

            <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="10" Margin="0,0,0,20" Height="250">
                <lvc:CartesianChart Series="{Binding BieuDoThoiGian}" XAxes="{Binding TrucXThoiGian}" LegendPosition="Right" />
            </Border>
        </StackPanel>
    </ScrollViewer>

</Page>