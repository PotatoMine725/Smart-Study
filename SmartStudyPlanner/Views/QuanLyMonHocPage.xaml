<Page x:Class="SmartStudyPlanner.QuanLyMonHocPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Quản Lý Môn Học">
      
    <StackPanel Margin="20">
        <Button Content="⬅ Quay lại Dashboard" HorizontalAlignment="Left" Background="Transparent" BorderBrush="Transparent" Foreground="#3498DB" FontWeight="Bold" Cursor="Hand" Margin="0,0,0,10"
                Command="{Binding QuayLaiCommand}"/>

        <TextBlock Text="{Binding TieuDe}" FontWeight="Bold" FontSize="18" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,5" Width="550">
            <TextBlock Text="Tên môn học" Width="300" Margin="0,0,10,0" Foreground="Gray" />
            <TextBlock Text="Tín chỉ" Width="80" Margin="0,0,10,0" Foreground="Gray" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20" Width="550">
            <TextBox Width="300" Height="30" Padding="5" Margin="0,0,10,0" VerticalContentAlignment="Center" 
                     Text="{Binding TenMon, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBox Width="80" Height="30" Padding="5" Margin="0,0,10,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" 
                     Text="{Binding SoTinChi, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Width="140" Height="30" FontWeight="Bold" Foreground="White" Cursor="Hand" 
                    Content="{Binding TextNutThem}" 
                    Background="{Binding MauNutThem}" 
                    Command="{Binding ThemMonCommand}" />
        </StackPanel>

        <DataGrid x:Name="dgDanhSachMon" Width="650" Height="300" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False" AlternatingRowBackground="#F9F9F9" HorizontalAlignment="Center"
                  ItemsSource="{Binding HocKyHienTai.DanhSachMonHoc}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tên Môn Học" Binding="{Binding TenMonHoc}" Width="*" />
                <DataGridTextColumn Header="Số Tín Chỉ" Binding="{Binding SoTinChi}" Width="80" />
                <DataGridTemplateColumn Header="Thao tác" Width="170">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Content="Tasks" Background="#9B59B6" Foreground="White" Padding="10,2" Margin="0,0,5,0" Cursor="Hand" 
                                        Command="{Binding DataContext.XemTaskCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />

                                <Button Content="Sửa" Background="#F1C40F" Foreground="White" Padding="10,2" Margin="0,0,5,0" Cursor="Hand" 
                                        Command="{Binding DataContext.SuaMonCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />

                                <Button Content="Xóa" Background="#E74C3C" Foreground="White" Padding="10,2" Cursor="Hand" 
                                        Command="{Binding DataContext.XoaMonCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </StackPanel>
</Page>